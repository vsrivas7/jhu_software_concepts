# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# Option A: full connection string (overrides all individual vars below)
DATABASE_URL=postgresql://gradcafe_user:yourpassword@localhost:5432/gradcafe

# Option B: individual connection variables
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gradcafe
DB_USER=gradcafe_user
DB_PASSWORD=yourpassword
